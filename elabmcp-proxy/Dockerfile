# Dockerfile for elabmcp-proxy (multi-user auth-proxy wrapping elabrmcp)
# Build context: monorepo root (the elabR/ project, not the elabmcp-proxy dir)
#
# Build from repo root:
#   docker build -f elabmcp-proxy/Dockerfile -t elabmcp-proxy .
#
# This image contains:
#   - R + elabR + elabrmcp  (same R subprocess backend)
#   - Python + elabmcp-proxy (auth proxy frontend)

FROM rocker/r-ver:4.4.2

# ÔöÇÔöÇ System dependencies ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
RUN apt-get update && apt-get install -y --no-install-recommends \
    libcurl4-gnutls-dev \
    libssl-dev \
    libxml2-dev \
    cmake \
    libmbedtls-dev \
    python3 \
    python3-pip \
    python3-venv \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

# ÔöÇÔöÇ Build environment tweaks ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
ENV MAKEFLAGS="-j1" \
    R_PARALLEL_PACKAGES=1 \
    R_DEFAULT_INTERNET_TIMEOUT=600

# ÔöÇÔöÇ Copy monorepo into /app ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
COPY elabR/ /app/elabR/

# ÔöÇÔöÇ Install CRAN dependencies ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
RUN R -e "install.packages('remotes', repos='https://cloud.r-project.org')" \
 && R -e "install.packages(c('httr2','jsonlite','yaml','cli','rlang'), repos='https://cloud.r-project.org')"

# ÔöÇÔöÇ Install root elabR package ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
RUN R -e "remotes::install_local('/app/elabR', dependencies = c('Depends','Imports'), upgrade = 'never')"

# ÔöÇÔöÇ Install ellmer and mcptools from CRAN ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
RUN R -e "install.packages(c('ellmer','mcptools'), repos='https://cloud.r-project.org')"

# ÔöÇÔöÇ Install elabrmcp subpackage ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
RUN R -e "remotes::install_local('/app/elabR/mcp/elabrmcp', dependencies = c('Depends','Imports'), upgrade = 'never')"

# ÔöÇÔöÇ Install elabmcp-proxy (Python) ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
COPY elabmcp-proxy /elabmcp-proxy
RUN pip3 install --break-system-packages -r /elabmcp-proxy/requirements.txt \
 && pip3 install --break-system-packages -e /elabmcp-proxy

# ÔöÇÔöÇ OpenShift arbitrary UID compatibility ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
RUN mkdir -p /var/log/elabmcp-proxy \
 && chgrp -R 0 /app /usr/local/lib/R/site-library /elabmcp-proxy /var/log/elabmcp-proxy \
 && chmod -R g+rwX /app /usr/local/lib/R/site-library /elabmcp-proxy /var/log/elabmcp-proxy

EXPOSE 8081

CMD ["python3", "-m", "elabmcp_proxy"]
