researchmcp.duckdns.org {
    root * /srv/http
    file_server browse

    @api path /dt/* /el/*
    @options {
        method OPTIONS
        path /dt/* /el/*
    }

    header @api {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, HEAD, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
        Access-Control-Expose-Headers "Content-Type"
        Cache-Control "no-cache"
        Connection "keep-alive"
        X-Accel-Buffering "no"
    }

    route {
        handle @options {
            respond "" 204
        }

        handle_path /dt/* {
            uri strip_prefix /dt
            reverse_proxy datatagger-mcp:8000 { flush_interval -1 }
        }

        handle_path /el/* {
            uri strip_prefix /el
            reverse_proxy elabmcp-proxy:8081 { flush_interval -1 }
        }
    }
}
