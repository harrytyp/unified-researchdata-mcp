elab-app.researchmcp.duckdns.org {
    reverse_proxy elab-app:8501 {
        flush_interval -1
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }
}

proespm.researchmcp.duckdns.org {
    reverse_proxy proespm-app:8501 {
        flush_interval -1
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }
}

researchmcp.duckdns.org {
    handle_path /dt* {
        uri strip_prefix /dt
        reverse_proxy datatagger-mcp:8000 {
            flush_interval -1
        }
    }

    handle_path /el* {
        uri strip_prefix /el
        reverse_proxy elabmcp-proxy:8081 {
            flush_interval -1
        }
    }

    handle /nomad-oasis/* {
        reverse_proxy proxy:80 {
            flush_interval -1
        }
    }

    root * /srv/http
    file_server browse

    @api path /dt/* /el/*
    @options method OPTIONS

    header @api {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods GET, POST, HEAD, OPTIONS
        Access-Control-Allow-Headers Content-Type, Authorization
        Access-Control-Expose-Headers Content-Type
        Cache-Control no-cache
        Connection keep-alive
        X-Accel-Buffering no
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    handle @options {
        respond  204
    }
}
