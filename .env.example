# ── JWT Secret (REQUIRED) ────────────────────────────────────────────────────
# Generate with: python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
MCP_JWT_SECRET=change-me-to-a-random-secret

# Token expiry in days (default: 30)
MCP_TOKEN_EXPIRY_DAYS=30

# ── External Service URLs ────────────────────────────────────────────────────
# Only change if self-hosting these services
FDM_BASE_URL=https://datatagger.ub.tum.de
